<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand d-flex align-items-center gap-2" href="">
            <img src="images/rodcast-logo.png" alt="Rodcast Solutions" style="height: 32px; width: 32px; object-fit: contain;" />
            <span>Rodcast Solutions</span>
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <i class="bi bi-house-door-fill me-2" aria-hidden="true"></i> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="clients">
                <i class="bi bi-people-fill me-2" aria-hidden="true"></i> Clientes
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="projects">
                <i class="bi bi-kanban-fill me-2" aria-hidden="true"></i> Proyectos
            </NavLink>
        </div>

        <AuthorizeView Roles="Admin">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="bank-accounts">
                        <i class="bi bi-bank2 me-2" aria-hidden="true"></i> Cuentas Bancarias
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="company-settings">
                        <i class="bi bi-building-gear me-2" aria-hidden="true"></i> Datos de la Empresa
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="invoices">
                <i class="bi bi-receipt me-2" aria-hidden="true"></i> Facturas
            </NavLink>
        </div>

        <AuthorizeView Roles="Admin">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="users">
                        <i class="bi bi-person-gear me-2" aria-hidden="true"></i> Usuarios
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
    </nav>

    <AuthorizeView>
        <Authorized>
            <div class="px-3 mt-4 text-white-50 small">
                <div>@(context.User.FindFirst("DisplayName")?.Value ?? context.User.Identity?.Name)</div>
                <form method="post" action="/account/logout">
                    <AntiforgeryToken />
                    <button class="btn btn-link btn-sm text-white-50 p-0" type="submit">Cerrar sesión</button>
                </form>
            </div>
        </Authorized>
    </AuthorizeView>
</div>

