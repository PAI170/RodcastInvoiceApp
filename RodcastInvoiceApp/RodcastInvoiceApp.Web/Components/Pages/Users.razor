@page "/users"
@attribute [Authorize(Roles = AppRoles.Admin)]
@using Microsoft.AspNetCore.Identity
@using RodcastInvoiceApp.Web.Data.Models
@inject UserManager<ApplicationUser> UserManager

<PageTitle>Usuarios</PageTitle>

<h1>Usuarios</h1>

@if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (users is null)
{
    <p><em>Cargando...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Email</th>
                <th>Rol</th>
                <th>Estado</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in users)
            {
                if (resettingUserId == u.Id)
                {
                    <tr>
                        <td colspan="5">
                            <div class="d-flex align-items-center gap-2">
                                <span>Nueva contraseña para <strong>@u.DisplayName</strong>:</span>
                                <input class="form-control form-control-sm" style="max-width: 220px;"
                                       type="password" placeholder="Mínimo 6 caracteres" @bind="newPassword" />
                                <button class="btn btn-primary btn-sm" @onclick="() => HandleResetPassword(u.Id)">Guardar</button>
                                <button class="btn btn-secondary btn-sm" @onclick="CancelReset">Cancelar</button>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    <tr>
                        <td>@u.DisplayName</td>
                        <td>@u.Email</td>
                        <td>@u.Role</td>
                        <td>
                            @if (u.IsLockedOut)
                            {
                                <span class="badge text-bg-danger">Bloqueado</span>
                            }
                            else
                            {
                                <span class="badge text-bg-success">Activo</span>
                            }
                        </td>
                        <td>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => StartReset(u.Id)">Restablecer contraseña</button>
                            @if (u.Id != currentUserId)
                            {
                                @if (u.IsLockedOut)
                                {
                                    <button class="btn btn-outline-success btn-sm" @onclick="() => HandleToggleLock(u.Id)">Desbloquear acceso</button>
                                }
                                else
                                {
                                    <button class="btn btn-outline-warning btn-sm" @onclick="() => HandleToggleLock(u.Id)">Bloquear acceso</button>
                                }
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => HandleDelete(u.Id)">Eliminar</button>
                            }
                            else
                            {
                                <span class="text-muted">(vos)</span>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
}

<h2>Nuevo usuario</h2>

<EditForm Model="newUser" FormName="NewUserForm" OnValidSubmit="HandleCreate">
    <div class="row g-2">
        <div class="col-md-3">
            <InputText class="form-control" placeholder="Nombre" @bind-Value="newUser.DisplayName" />
        </div>
        <div class="col-md-3">
            <InputText class="form-control" placeholder="Email" @bind-Value="newUser.Email" />
        </div>
        <div class="col-md-3">
            <InputText class="form-control" placeholder="Contraseña (mínimo 6 caracteres)" type="password" @bind-Value="newUser.Password" />
        </div>
        <div class="col-md-2">
            <InputSelect class="form-select" @bind-Value="newUser.Role">
                <option value="@AppRoles.Admin">Admin</option>
                <option value="@AppRoles.Employee">Employee</option>
            </InputSelect>
        </div>
    </div>
    <button type="submit" class="btn btn-primary mt-2">Crear usuario</button>
</EditForm>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    private List<UserRow>? users;
    private NewUserModel newUser = new();
    private string? errorMessage;
    private string? currentUserId;
    private string? resettingUserId;
    private string newPassword = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask is not null)
        {
            var authState = await AuthStateTask;
            currentUserId = UserManager.GetUserId(authState.User);
        }

        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        var list = new List<UserRow>();
        foreach (var user in UserManager.Users.ToList())
        {
            var roles = await UserManager.GetRolesAsync(user);
            list.Add(new UserRow
            {
                Id = user.Id,
                DisplayName = user.DisplayName,
                Email = user.Email ?? string.Empty,
                Role = roles.FirstOrDefault() ?? "(sin rol)",
                IsLockedOut = await UserManager.IsLockedOutAsync(user)
            });
        }

        users = list;
    }

    private async Task HandleCreate()
    {
        errorMessage = null;
        try
        {
            var user = new ApplicationUser
            {
                UserName = newUser.Email,
                Email = newUser.Email,
                DisplayName = newUser.DisplayName
            };

            var result = await UserManager.CreateAsync(user, newUser.Password);
            if (!result.Succeeded)
            {
                errorMessage = string.Join(" ", result.Errors.Select(e => e.Description));
                return;
            }

            await UserManager.AddToRoleAsync(user, newUser.Role);
            newUser = new NewUserModel();
            await LoadUsersAsync();
        }
        catch (Exception)
        {
            errorMessage = "No se pudo completar la acción. Intentá de nuevo en unos segundos.";
        }
    }

    private async Task HandleDelete(string id)
    {
        if (id == currentUserId)
            return;

        errorMessage = null;
        try
        {
            var user = await UserManager.FindByIdAsync(id);
            if (user is null)
                return;

            await UserManager.DeleteAsync(user);
            await LoadUsersAsync();
        }
        catch (Exception)
        {
            errorMessage = "No se pudo completar la acción. Intentá de nuevo en unos segundos.";
        }
    }

    private async Task HandleToggleLock(string id)
    {
        if (id == currentUserId)
            return;

        errorMessage = null;
        try
        {
            var user = await UserManager.FindByIdAsync(id);
            if (user is null)
                return;

            if (await UserManager.IsLockedOutAsync(user))
            {
                await UserManager.SetLockoutEndDateAsync(user, null);
            }
            else
            {
                // Bloquea logins futuros y, via UpdateSecurityStampAsync, invalida
                // tambien cualquier sesion ya activa (se corta sola en <= 1 minuto,
                // ver SecurityStampValidatorOptions en Program.cs).
                await UserManager.SetLockoutEnabledAsync(user, true);
                await UserManager.SetLockoutEndDateAsync(user, DateTimeOffset.MaxValue);
                await UserManager.UpdateSecurityStampAsync(user);
            }

            await LoadUsersAsync();
        }
        catch (Exception)
        {
            errorMessage = "No se pudo completar la acción. Intentá de nuevo en unos segundos.";
        }
    }

    private void StartReset(string id)
    {
        errorMessage = null;
        resettingUserId = id;
        newPassword = string.Empty;
    }

    private void CancelReset()
    {
        resettingUserId = null;
        newPassword = string.Empty;
    }

    private async Task HandleResetPassword(string id)
    {
        errorMessage = null;

        // Se valida el largo antes de tocar nada: si RemovePasswordAsync ya corrio
        // y AddPasswordAsync falla despues, el usuario queda sin contraseña del todo.
        if (newPassword.Length < 6)
        {
            errorMessage = "La contraseña debe tener al menos 6 caracteres.";
            return;
        }

        try
        {
            var user = await UserManager.FindByIdAsync(id);
            if (user is null)
                return;

            // No hace falta la contraseña actual: quien entra a esta pagina ya es Admin.
            var removeResult = await UserManager.RemovePasswordAsync(user);
            if (!removeResult.Succeeded)
            {
                errorMessage = string.Join(" ", removeResult.Errors.Select(e => e.Description));
                return;
            }

            var addResult = await UserManager.AddPasswordAsync(user, newPassword);
            if (!addResult.Succeeded)
            {
                errorMessage = string.Join(" ", addResult.Errors.Select(e => e.Description));
                return;
            }

            CancelReset();
        }
        catch (Exception)
        {
            errorMessage = "No se pudo completar la acción. Intentá de nuevo en unos segundos.";
        }
    }

    private class UserRow
    {
        public string Id { get; set; } = string.Empty;
        public string DisplayName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Role { get; set; } = string.Empty;
        public bool IsLockedOut { get; set; }
    }

    private class NewUserModel
    {
        public string DisplayName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string Role { get; set; } = AppRoles.Employee;
    }
}
